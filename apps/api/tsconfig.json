{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2023",
    "outDir": "dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "isolatedModules": false,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "jest.config.ts",
    "jest.e2e.config.ts",
    "prisma.config.ts",
    "prisma/**/*"
  ]
}
