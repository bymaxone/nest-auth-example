# ---------------------------------------------------------------------------
# apps/api — environment variables
# Copy to .env and fill in real values. Never commit .env.
# See docs/DEVELOPMENT_PLAN.md Appendix A for the full registry.
# ---------------------------------------------------------------------------

NODE_ENV=development
LOG_LEVEL=info
API_PORT=4000
WEB_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (PostgreSQL 18 via docker-compose.yml)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/example_app?schema=public
# DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:55432/example_app_test?schema=public

# ---------------------------------------------------------------------------
# Redis (Redis 7 via docker-compose.yml)
# ---------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# JWT / Auth
# ---------------------------------------------------------------------------
# JWT_SECRET=<openssl rand -hex 64>   # must be >=32 chars, high entropy
# MFA_ENCRYPTION_KEY=<openssl rand -base64 32>   # exactly 32 bytes, base64

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------
# EMAIL_PROVIDER=mailpit   # mailpit | resend
# SMTP_HOST=localhost
# SMTP_PORT=1025
SMTP_FROM=no-reply@nest-auth-example.dev
# RESEND_API_KEY=

# ---------------------------------------------------------------------------
# OAuth (optional — both vars required to enable Google OAuth)
# ---------------------------------------------------------------------------
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/oauth/google/callback

# ---------------------------------------------------------------------------
# Password reset
# ---------------------------------------------------------------------------
# PASSWORD_RESET_METHOD=token   # token | otp
