# ---------------------------------------------------------------------------
# apps/api -- environment variables
# Copy to .env and fill in real values. Never commit .env.
# See docs/DEVELOPMENT_PLAN.md Appendix A for the full registry.
# ---------------------------------------------------------------------------

NODE_ENV=development
LOG_LEVEL=info
API_PORT=4000
WEB_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Database (PostgreSQL 18 via docker-compose.yml)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/example_app?schema=public
# DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:55432/example_app_test?schema=public

# ---------------------------------------------------------------------------
# Redis (Redis 7 via docker-compose.yml)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
# REDIS_NAMESPACE=nest-auth-example   # optional; defaults to nest-auth-example

# ---------------------------------------------------------------------------
# JWT / Auth
# ---------------------------------------------------------------------------
JWT_SECRET=                  # openssl rand -hex 64   (required, >= 64 chars)
MFA_ENCRYPTION_KEY=          # openssl rand -base64 32  (required, 32-byte base64)

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------
EMAIL_PROVIDER=mailpit        # mailpit | resend
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@nest-auth-example.dev
# RESEND_API_KEY=             # required when EMAIL_PROVIDER=resend

# ---------------------------------------------------------------------------
# OAuth (optional -- both vars required to enable Google OAuth)
#
# IMPORTANT: the callback URL points to the WEB origin (port 3000), not the
# API. Next.js rewrites `/api/:path*` straight to the NestJS API, so the
# request is forwarded transparently — but the browser sees the response as
# coming from the web origin, which keeps the post-callback redirect to
# `/dashboard` same-origin and lets the auth cookies travel without
# SameSite=Strict tripping on a cross-port hop. Update the "Authorized
# redirect URIs" entry in Google Cloud Console to match this exact URL.
# ---------------------------------------------------------------------------
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/google/callback

# ---------------------------------------------------------------------------
# Password reset
# ---------------------------------------------------------------------------
# PASSWORD_RESET_METHOD=token   # token | otp

# ---------------------------------------------------------------------------
# Tenant-level MFA enforcement (optional, default empty)
#
# Comma-separated list of tenant slugs (see apps/api/prisma/seed.ts) whose
# users MUST enrol in MFA before they can use any protected endpoint.
# Enforced by `TenantMfaPolicyGuard` (apps/api/src/auth/tenant-mfa-policy.guard.ts)
# and surfaced in the UI as a banner on /dashboard/security.
#
# Default (empty) = no enforcement, every tenant is unaffected. To demo the
# policy against the seed's globex workspace, set:
# ---------------------------------------------------------------------------
# MFA_REQUIRED_TENANT_SLUGS=globex
