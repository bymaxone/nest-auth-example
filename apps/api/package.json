  "description": "NestJS 11 API for nest-auth-example — wires @bymax-one/nest-auth with Prisma, Redis, and Mailpit.",
  "license": "MIT",
  "author": {
    "name": "Bymax One",
    "url": "https://bymax.one"
  },
