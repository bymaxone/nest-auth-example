# apps/web — Environment Variables
# Copy to .env.local for local development. Never commit .env.local.
# All keys are validated at startup in lib/env.ts — the server refuses to start
# if any required key is missing or malformed.

# ── Server-only ──────────────────────────────────────────────────────────────
# Internal URL the Next.js server uses to proxy /api/* to NestJS.
# Must NOT be exposed to the browser — used only in rewrites and server fetch.
INTERNAL_API_URL=http://localhost:4000

# HS256 secret mirroring the API's JWT_SECRET.
# Used by createAuthProxy to verify access-token cookies without a round-trip.
# MUST match apps/api JWT_SECRET exactly. Min 32 characters.
AUTH_JWT_SECRET_FOR_PROXY=change-me-to-a-strong-secret-at-least-32-chars

# ── Public (NEXT_PUBLIC_*) ────────────────────────────────────────────────────
# Browser-visible API base URL. In dev this is the same-origin /api proxy.
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# WebSocket gateway URL — direct to NestJS (not proxied through Next.js).
NEXT_PUBLIC_WS_URL=http://localhost:4000

# Enable the Google OAuth login button (requires API GOOGLE_CLIENT_ID/SECRET).
NEXT_PUBLIC_OAUTH_GOOGLE_ENABLED=false
