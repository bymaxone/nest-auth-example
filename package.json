{
  "name": "nest-auth-example",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.8"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --if-present run dev",
