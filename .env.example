# ---------------------------------------------------------------------------
# Shared environment variables (see docs/DEVELOPMENT_PLAN.md Appendix A)
# ---------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
# PUBLIC_DOMAIN=example.com   # optional; used by cookies.resolveDomains in prod

# ---------------------------------------------------------------------------
# Docker Compose -- local infrastructure (docker-compose.yml)
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
# Change POSTGRES_PASSWORD before using in any non-local environment.
POSTGRES_PASSWORD=postgres
POSTGRES_DB=example_app

# ---------------------------------------------------------------------------
# apps/api
# ---------------------------------------------------------------------------
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/example_app?schema=public
# DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:55432/example_app_test?schema=public
REDIS_URL=redis://localhost:6379
# REDIS_NAMESPACE=nest-auth-example   # optional; defaults to nest-auth-example

# ---------------------------------------------------------------------------
# JWT / Auth
# ---------------------------------------------------------------------------
JWT_SECRET=                  # openssl rand -hex 64   (required, >= 64 chars)
MFA_ENCRYPTION_KEY=          # openssl rand -base64 32  (required, 32-byte base64)

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------
EMAIL_PROVIDER=mailpit        # mailpit | resend
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@nest-auth-example.dev
# RESEND_API_KEY=             # required when EMAIL_PROVIDER=resend

# ---------------------------------------------------------------------------
# OAuth — Google (optional)
# ---------------------------------------------------------------------------
# Step-by-step setup guide: docs/OAUTH_GOOGLE.md
#
# To enable Google OAuth ALL THREE vars must be set together (Zod refuses to
# start the app on partial config). To disable, leave all three commented out.
#
# How to obtain the values:
#   1. Open https://console.cloud.google.com/apis/credentials
#   2. Create credentials → OAuth client ID → Web application
#   3. Register the callback URL below as an Authorized redirect URI on Google
#   4. Copy the Client ID + Client secret into the two lines below
#
# Callback URL points to the WEB origin (port 3000), not the API. Next.js
# rewrites `/api/:path*` to the NestJS API transparently, so the response
# (Set-Cookie + 302 to /dashboard) appears to come from the web origin —
# which keeps the post-callback redirect same-origin and the auth cookies
# travel without SameSite=Strict tripping on a cross-port hop.
# OAUTH_GOOGLE_CLIENT_ID=<your-id>.apps.googleusercontent.com
# OAUTH_GOOGLE_CLIENT_SECRET=<your-secret>
# OAUTH_GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/google/callback

# ---------------------------------------------------------------------------
# Tenant-level MFA enforcement (optional)
# ---------------------------------------------------------------------------
# Comma-separated list of tenant SLUGS whose users must enrol in MFA
# (TOTP) before they can use any protected endpoint. Enforced server-side
# by TenantMfaPolicyGuard; the dashboard shell redirects unenrolled users
# in these tenants to /dashboard/security on every navigation.
#
# Default = empty (no enforcement). To demo against the seed's globex
# workspace, set the line below.
# MFA_REQUIRED_TENANT_SLUGS=globex

# ---------------------------------------------------------------------------
# apps/web
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:3000/api
# INTERNAL_API_URL=http://localhost:4000
# AUTH_JWT_SECRET_FOR_PROXY=   # same as JWT_SECRET above
# NEXT_PUBLIC_WS_URL=ws://localhost:4000
#
# Flip to `true` AFTER the three OAUTH_GOOGLE_* vars above are set in apps/api/.env.
# The "Continue with Google" button on /auth/login + /auth/register reads this
# flag at Next build time, so restart `pnpm dev` after changing the value.
# NEXT_PUBLIC_OAUTH_GOOGLE_ENABLED=false
